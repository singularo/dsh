#!/bin/bash

#
# This file serves as the main entrypoint for development of
# shepherd based projects. It provides a simple bash shell based
# development environment.
#

# Exit on errors, undefined variables, and pipe failures.
set -euo pipefail

# Project is used as the prefix for docker networking, container naming and nginx hostname.
# Source the .env file here, the project var is required asap.
if [ -f .env ]; then
  source .env
fi
PROJECT=${PROJECT:-$(basename "${PWD}" | tr -d '.')}
COMPOSER_PROJECT=${PROJECT}
export PROJECT
export COMPOSER_PROJECT

# Work out some other values we need.
HOST_TYPE=$(uname | tr '[:upper:]' '[:lower:]')
COMPOSE_FILE="docker-compose.${HOST_TYPE}.yml"
DOCKER_COMPOSE="docker-compose --ansi never"
DOCKER_COMPOSE_QUIET="docker-compose --ansi never --progress quiet"
SHELL_CONTAINER=web

# Set domain default if its not set.
# Default uses nip.io which provides wildcard DNS without any local configuration.
# Any subdomain of <ip>.nip.io resolves to that IP address.
# Custom domains can be set via DOMAIN environment variable in .env.
set +u
if [[ "${HOST_TYPE}" =~ 'darwin' ]]; then
  if [ -z "${DOMAIN}" ]; then
    DOMAIN="127.0.0.1.nip.io"
  fi
  CONTAINER_SSH_AUTH_SOCK=/run/host-services/ssh-auth.sock
  export CONTAINER_SSH_AUTH_SOCK
else
  if [ -z "${DOMAIN}" ]; then
    DOMAIN="172.17.0.1.nip.io"
  fi
  # If ssh is setup, try and add it in.
  if [ -n "${SSH_AUTH_SOCK}" ]; then
    CONTAINER_SSH_AUTH_SOCK=/ssh/$(basename "${SSH_AUTH_SOCK}")
    export CONTAINER_SSH_AUTH_SOCK
  fi
fi
set -u
export DOMAIN

# Set user variables
USER_ID=$(id -u)
export USER_ID
GROUP_ID=$(id -g)
export GROUP_ID

# Setup some functions to output warnings.
notice()  { printf "\e[32;01m%s\e[39;49;00m\n" "$1"; }
warning() { printf "\e[33;01m%s\e[39;49;00m\n" "$1"; }
error()   { printf "\e[31;01m%s\e[39;49;00m\n" "$1"; }

# Ensure required docker file is at least present
if [ ! -f "${COMPOSE_FILE}" ]; then
  # Ultimately permit overriding repo docker-compose.yml with custom file.
  if [ -f docker-compose.yml ]; then
    COMPOSE_FILE='docker-compose.yml'
  else
    error "Unable to locate ${COMPOSE_FILE} in current directory."
    exit 1
  fi
fi

# Fix for Specifying a compose file breaks override loading.
if [ -f "docker-compose.override.yml" ]; then
  COMPOSE_FILE="${COMPOSE_FILE}:docker-compose.override.yml"
fi
export COMPOSE_FILE

# Ensure script is NOT running inside a container - must be run from host.
if [ -f /.dockerenv ]; then
  error "Inception error - you can't run $0 within a docker container."
  exit 1
fi

# Ensure the shared dsh_network exists. This external network persists across
# compose up/down cycles, preventing network interface churn that causes
# ERR_NETWORK_CHANGED in Chromium-based browsers.
# Must be called before docker compose up, as compose validates external networks.
#
# Args:
#   $1 - Optional "quiet" flag to suppress output messages
ensure_network() {
  if ! docker network ls --format "{{.Name}}" --filter "name=^dsh_network$" | grep -q "dsh_network"; then
    if [ "${1:-}" != "quiet" ]; then
      notice "Creating dsh_network."
    fi
    docker network create dsh_network > /dev/null
  fi
}

# Setup and configure the nginx-proxy container for routing traffic to project containers.
# This function ensures the nginx-proxy container is running and connected to dsh_network.
#
# Args:
#   $1 - Optional "quiet" flag to suppress output messages
#
# The nginx-proxy container:
#   - Routes traffic based on VIRTUAL_HOST environment variables
#   - Listens on port 8080 for all project URLs
#   - Automatically discovers containers via docker socket
#   - Connects to dsh_network for internal routing
setup_nginx() {
  # Check if nginx-proxy container exists (running or stopped).
  if docker ps -a --format "{{.Names}}" | grep nginx-proxy > /dev/null; then
    if [ "${1:-}" != "quiet" ]; then
      warning "Restarting nginx proxy"
    fi
    docker restart nginx-proxy > /dev/null
  else
    if [ "${1:-}" != "quiet" ]; then
      warning "Starting nginx proxy"
    fi
    docker run -d -p 8080:80  \
      -v /var/run/docker.sock:/tmp/docker.sock:ro \
      -v ./docker/dsh_proxy.conf:/etc/nginx/conf.d/dsh_proxy.conf \
      --restart always --name nginx-proxy \
      nginxproxy/nginx-proxy:1.3.1 > /dev/null
  fi

  if ! docker ps --format "{{.Names}}" --filter "name=^nginx-proxy$" | grep -q "nginx-proxy"; then
    error "nginx-proxy could not be started."
  fi

  # Connect nginx-proxy to dsh_network if not already connected.
  # This allows nginx to route traffic to containers on the shared network.
  set +e
  URL="http://${PROJECT}.${DOMAIN}:8080"
  NGINX_IP=$(docker inspect --format '{{with index .NetworkSettings.Networks "dsh_network"}}{{.IPAddress}}{{end}}' nginx-proxy)
  # Check if we got a valid IP address (nginx is already on the network).
  if [[ ! ${NGINX_IP} =~ ^[0-9]+\.[0-9]+\.[0-9]+\.[0-9]+$ ]]; then
    if [ "${1:-}" != "quiet" ]; then
      notice "Connecting nginx-proxy to the network."
    fi
    docker network connect dsh_network nginx-proxy > /dev/null
  fi
  set -e
}

# Handle nginx-proxy on project stop.
# The shared dsh_network persists - no disconnect needed.
stop_nginx() {
  # Note: We no longer disconnect nginx-proxy from dsh_network on stop.
  # The shared network persists across all projects and nginx-proxy stays
  # connected to serve other running projects.
  notice "Nginx proxy left connected to dsh_network."
}

# Command: ./dsh start
# Start all project containers, create network if needed, and setup nginx-proxy routing.
#
# Args:
#   $1 - Optional "quiet" flag to suppress output messages
#
# This function:
#   1. Checks if containers are already running (skips if already started)
#   2. Starts all services defined in docker-compose file
#   3. Creates docker network if it doesn't exist
#   4. Configures nginx-proxy for HTTP routing
#   5. Displays the project URL when complete
dsh_start() {
  # Check if web container is already running.
  if [[ ! $(docker ps --format "{{.Names}}" --filter "name=^${PROJECT}_web") =~ ${PROJECT}_web ]]; then
    set +u
    if [ "${1:-}" != "quiet" ]; then
      notice "Starting containers."
    fi
    set -u
    # Create the external network before compose up, as compose validates it exists.
    ensure_network "${1:-}"
    if [ "${1:-}" != "quiet" ]; then
      ${DOCKER_COMPOSE} up -d
    else
      ${DOCKER_COMPOSE_QUIET} up -d
    fi
    # Too slow to leave in # ${DOCKER_COMPOSE} build --parallel
    setup_nginx "${1:-}"

    URL="http://${PROJECT}.${DOMAIN}:8080"
    set +u
    if [ "${1:-}" != "quiet" ]; then
      notice "Please wait about 10 seconds for the database to settle.
The project is now available at: ${URL}.
Files are available in /code, You may need to 'robo build' to install."
    fi
    set -u
  fi
}

# Command: ./dsh shell
# Connect to the web container as the current user for running commands or interactive shell.
#
# Usage:
#   ./dsh shell                    - Opens interactive bash shell
#   ./dsh shell "command"          - Runs command in container
#   ./dsh shell "command" | grep   - Runs command without TTY (for piping)
#
# This function:
#   1. Ensures containers are started (quietly if running a command)
#   2. Creates a user in the container matching your local user ID (prevents permission issues)
#   3. Passes through environment variables needed for testing and development
#   4. Handles both interactive shells and command execution
#   5. Detects if output is piped and adjusts TTY allocation accordingly
dsh_shell() {
  # Start containers quietly if running a command, with output if interactive.
  if [ $# -gt 0 ]; then
    dsh_start quiet
  else
    dsh_start
  fi

  # Setup a user in the container matching the host user ID to avoid permission issues.
  # Check if www-data user ID matches our local user ID.
  EXISTING_USER=$(${DOCKER_COMPOSE} exec ${SHELL_CONTAINER} id -u www-data 2>/dev/null | sed -e 's/\r//g' || echo "")
  if [ "${EXISTING_USER}" != "${USER_ID}" ]; then
    # www-data doesn't match, check if our user already exists in container.
    if ! ${DOCKER_COMPOSE} exec ${SHELL_CONTAINER} id -u "${USER}" >/dev/null 2>&1; then
      notice "Setting up user $USER on web container."
      # Create user with matching UID and grant sudo access.
      ${DOCKER_COMPOSE} exec ${SHELL_CONTAINER} adduser --disabled-password --uid "${USER_ID}" \
        --gecos "${USER}" --home "/home/${USER}" "${USER}" >/dev/null
      ${DOCKER_COMPOSE} exec ${SHELL_CONTAINER} /bin/bash -c "echo '${USER} ALL=(ALL) NOPASSWD: ALL' > /etc/sudoers.d/${USER}" > /dev/null
    fi
  else
    # www-data UID matches, use www-data user.
    USER=www-data
  fi

  # Build array of environment variables to pass to the container.
  options=()

  # Helper: add env var only if set on host.
  add_env_if_set() {
    local var=$1 container_var=${2:-$1}
    set +u; local value="${!var:-}"; set -u
    if [ -n "$value" ]; then
      options+=("--env ${container_var}=${value}")
    fi
  }

  # Optional testing and monitoring variables.
  add_env_if_set DTT_BASE_URL
  add_env_if_set DTT_MINK_DRIVER_ARGS
  add_env_if_set SIMPLETEST_BASE_URL
  add_env_if_set SIMPLETEST_DB
  add_env_if_set NEWRELIC_ENABLED
  add_env_if_set NEWRELIC_APP
  add_env_if_set NEWRELIC_LICENSE
  add_env_if_set CONTAINER_SSH_AUTH_SOCK SSH_AUTH_SOCK

  # Required variables.
  options+=("--env PROJECT=${PROJECT}")
  options+=("--env DOMAIN=${DOMAIN}")
  options+=("--env COLUMNS=$(tput cols)")
  options+=("--env LINES=$(tput lines)")
  options+=("--env TERM=${TERM:-xterm}")

  # Execute command or start interactive shell.
  if [ $# -gt 0 ]; then
    # Running a command (not interactive shell).
    # Check if stdout is a terminal (TTY) or being piped/redirected.
    if [ ! -t 1 ]; then
      # Output is being piped/redirected, don't allocate TTY.
      ${DOCKER_COMPOSE} exec \
        -u "${USER}" \
        ${options[@]} \
        ${SHELL_CONTAINER} bash -c "$*"
    else
      # Interactive command, allocate TTY
      ${DOCKER_COMPOSE} exec \
        -u "${USER}" \
        -it \
        ${options[@]} \
        ${SHELL_CONTAINER} bash -c "$*"
    fi
  else
    # For interactive shell, use default behavior
    ${DOCKER_COMPOSE} exec \
      -u "${USER}" \
      -it \
      ${options[@]} \
      ${SHELL_CONTAINER} ./dsh_bash
  fi
}

# Command: ./dsh stop
# Stops project and brings down network after disconnecting nginx proxy.
dsh_stop() {
  notice "Stopping containers."
  stop_nginx
  ${DOCKER_COMPOSE_QUIET} stop
}

# Command: ./dsh down
# Stops project, then takes down containers and removes volumes if possible.
dsh_down() {
  stop_nginx
  notice "Removing containers."
  ${DOCKER_COMPOSE_QUIET} down -v
}

# Command: ./dsh purge
# Complete cleanup: stops containers, removes volumes, networks, and deletes all Docker images.
#
# WARNING: This is destructive and removes all data and images for this project.
#
# This function:
#   1. Runs dsh_down to stop and remove containers/volumes
#   2. Extracts image names from docker-compose files
#   3. Forcefully removes all Docker images used by the project
#   4. Useful for complete cleanup or troubleshooting image issues
dsh_purge() {
  dsh_down

  # Extract all image names from the compose file(s).
  # shellcheck disable=SC2086
  RESULTS=$(grep -h 'image:' ${COMPOSE_FILE//:/ })

  # Convert grep results into an array of lines.
  LINES=()
  while IFS= read -r line; do
    LINES+=("$line")
  done <<< "$RESULTS"

  # Remove each Docker image referenced in the compose files.
  for LINE in "${LINES[@]}"
  do
    # Extract image name by removing "image: " prefix.
    IMAGE=${LINE#*image: }
    # Force remove image, ignore errors if already removed.
    docker rmi -f "${IMAGE}" > /dev/null 2>&1
  done
}

# Command: ./dsh status
# Shows status information about project containers.
dsh_status() {
  ${DOCKER_COMPOSE} ps
}

# Command: ./dsh logs
# Tails logs from web container.
dsh_logs() {
  ${DOCKER_COMPOSE} logs -n 100 -f web
}

# Command: ./dsh pull
# Fetches all images used by the project.
dsh_pull() {
  # docker-compose doesn't resolve sub-dependencies in Dockerfiles.
  BASE_IMAGE=${BASE_IMAGE:-singularo/s2i-shepherd-drupal}
  docker pull "${BASE_IMAGE}" > /dev/null
  ${DOCKER_COMPOSE_QUIET} pull --ignore-pull-failures
  ${DOCKER_COMPOSE_QUIET} build
}

dsh_help() {
  printf "\nUsage: dsh [COMMAND] [ARGS...]\n
Commands:
\t down\tShutdown and destroy the containers.
\t help\tShow this help.
\t logs\tShow the container logs with tail -f - ctrl-c to exit.
\t pull\tPull the latest container images.
\t purge\tPurge the docker containers, network and proxy and remove all data.
\t shell\tStart a shell which is connected to the containers and can be used to run commands.
\t start\tStart the docker containers, network and proxy.
\t status\tShow the status of this projects containers.
\t stop\tStop the docker containers, network and proxy, but keep data for a re-start.
\nIf no command is given, shell is the default.
Commands can be shortened to their unique component, eg ./dsh sh is the same as ./dsh shell.
Any other arguments will be executed as a command in the container.\n\n"
}

# Set a default command to show usage when no arguments provided.
COMMAND=${1:-default}

case ${COMMAND} in
  dow*)
    dsh_down
    ;;
  h*|-h|--help)
    dsh_help
    ;;
  log*)
    dsh_logs
    ;;
  pul*)
    dsh_pull
    ;;
  pur*)
    dsh_purge
    ;;
  sh*|ss*)
    dsh_shell "${@:2}"
    ;;
  star*)
    dsh_start
    ;;
  stat*)
    dsh_status
    ;;
  sto*)
    dsh_stop
    ;;
  default)
    warning "Starting shell. For other options try $0 help."
    dsh_shell
    ;;
  *)
    # Execute the command and its arguments in the container
    dsh_shell "$@"
    ;;
esac
